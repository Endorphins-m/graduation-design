{
  "easycom": {
    "^u-(.*)": "uview-ui/components/u-$1/u-$1.vue"
  },
  "pages": [
	{
	      "path": "pages/login/login",
	      "style": {
	        "navigationStyle": "custom"
	      }
	    },
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "公考智学",
        "navigationBarBackgroundColor": "#2E5BFF",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/assessment/assessment",
      "style": {
        "navigationBarTitleText": "能力测评",
        "navigationBarBackgroundColor": "#2E5BFF"
      }
    },
    {
      "path": "pages/plan/plan",
      "style": {
        "navigationBarTitleText": "学习计划",
        "navigationBarBackgroundColor": "#ffffff"
      }
    },
	{
	  "path": "pages/library/library",
	  "style": {
		"navigationBarTitleText": "题库",
		"enablePullDownRefresh": false
	  }
	},
    {
      "path": "pages/practice/practice",
      "style": {
        "navigationBarTitleText": "在线刷题",
        "navigationStyle": "custom" 
      }
    },
    {
      "path": "pages/profile/profile",
      "style": {
        "navigationBarTitleText": "个人中心",
        "navigationBarBackgroundColor": "#f5f5f5"
      }
    },
    {
      "path": "pages/profile/user-edit",
      "style": {
        "navigationBarTitleText": "修改个人信息",
        "navigationBarBackgroundColor": "#f5f5f5"
      }
    }
  ],
  "tabBar": {
    "list": [
      {
        "pagePath": "pages/plan/plan",
        "text": "计划",
        "iconPath": "static/tabbar/plan.png",
        "selectedIconPath": "static/tabbar/plan-active.png"
      },
      {
        "pagePath": "pages/library/library",
        "text": "刷题",
        "iconPath": "static/tabbar/practice.png",
        "selectedIconPath": "static/tabbar/practice-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png"
      }
    ],
    "selectedColor": "#2E5BFF",
    "backgroundColor": "#ffffff"
  },
  "globalStyle": {
    "backgroundColor": "#f5f5f5"
  }
}