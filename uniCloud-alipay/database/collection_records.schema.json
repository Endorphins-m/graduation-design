{
  "bsonType": "object",
  "required": ["userId", "questionId", "moduleType"],
  "permission": {
    "read": "doc.userId == auth.uid",
    "create": "auth.uid != null",
    "update": "doc.userId == auth.uid",
    "delete": "doc.userId == auth.uid"
  },
  "properties": {
    "_id": { "description": "唯一标识" },
    "userId": { "bsonType": "string", "description": "关联用户ID" },
    "questionId": { "bsonType": "string", "description": "关联题目ID" },
    "moduleType": { "bsonType": "string", "description": "题目所属模块(verbal/quantitative等)" },
    "createTime": { "bsonType": "timestamp", "description": "收藏时间" }
  }
}