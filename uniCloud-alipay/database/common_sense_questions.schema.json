{
  "bsonType": "object",
  "required": ["content", "options", "answer", "difficulty", "analysis"],
  "permission": {
    "read": true,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": { "description": "题目唯一标识" },
    "content": { "bsonType": "string", "description": "题目题干" },
    "options": { "bsonType": "array", "items": { "bsonType": "string" } },
    "answer": { "bsonType": "int", "description": "正确答案索引" },
    "difficulty": { "bsonType": "int", "minimum": 1, "maximum": 5 },
    "analysis": { "bsonType": "string", "description": "题目解析" },
    "recommendedTime": { "bsonType": "int", "description": "推荐用时（秒）" },
    "knowledgePoints": { 
      "bsonType": "array", 
      "items": { "bsonType": "string" },
      "description": "知识点：法律常识、地理、人文历史、科技等"
    },
    "source": { "bsonType": "string" },
    "tags": { "bsonType": "array", "items": { "bsonType": "string" } }
  }
}